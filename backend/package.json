    "express": "5.2.1",
    "jsonwebtoken": "9.0.2",
    "lodash": "4.18.1",
    "node-fetch": "2.7.0",
    "sqlite3": "6.0.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "1.4.7",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.12",
    "@types/jsonwebtoken": "9.0.6",
    "@types/node": "20.14.2",
    "@types/node-fetch": "2.6.11",
    "@types/supertest": "6.0.2",
    "jest": "29.7.0",
    "supertest": "6.3.4",
    "ts-jest": "29.1.4",
    "ts-node-dev": "2.0.0",
    "typescript": "5.4.5"
