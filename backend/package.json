{
  "name": "retirement-planner-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Retirement Planner API (intentionally vulnerable demo backend)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
